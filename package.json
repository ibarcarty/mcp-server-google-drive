{
  "name": "@ibarcarty/mcp-server-google-drive",
  "version": "1.1.0",
  "description": "MCP server for Google Drive, Google Docs, Google Sheets, and Google Slides with full read/write operations, rich markdown-to-docs formatting, theming, shared drive support, and OAuth2 authentication",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-google-drive": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "google-drive",
    "google-docs",
    "google-sheets",
    "google-slides",
    "google-workspace",
    "ai",
    "tools",
    "claude",
    "shared-drives",
    "llm",
    "markdown",
    "gfm"
  ],
  "author": "Ibar Carty",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibarcarty/mcp-server-google-drive"
  },
  "homepage": "https://github.com/ibarcarty/mcp-server-google-drive",
  "bugs": {
    "url": "https://github.com/ibarcarty/mcp-server-google-drive/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "google-auth-library": "^10.6.0",
    "googleapis": "^171.0.0",
    "mdast-util-to-string": "^4.0.0",
    "open": "^11.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  }
}
