# Path to your OAuth client credentials JSON (downloaded from GCP Console)
# GDRIVE_MCP_OAUTH_PATH=~/.config/mcp-server-google-drive/oauth-credentials.json

# Path where tokens will be saved after authentication
# GDRIVE_MCP_TOKEN_PATH=~/.config/mcp-server-google-drive/tokens.json

# OAuth scopes (comma-separated). Use 'drive' for full access or 'drive.file' for per-file access
# GDRIVE_MCP_SCOPES=https://www.googleapis.com/auth/drive

# Transport mode: 'stdio' for local or 'http' for remote deployment
# GDRIVE_MCP_TRANSPORT=stdio

# HTTP port (only used when GDRIVE_MCP_TRANSPORT=http)
# GDRIVE_MCP_PORT=8080

# HTTP bind address (only used when GDRIVE_MCP_TRANSPORT=http)
# GDRIVE_MCP_HOST=0.0.0.0

# For Cloud Run: pass credentials as JSON strings instead of file paths
# GDRIVE_MCP_OAUTH_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["http://localhost"]}}
# GDRIVE_MCP_TOKENS_JSON={"access_token":"...","refresh_token":"...","expiry_date":...}
